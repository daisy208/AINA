generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  firstName    String?
  lastName     String?
  password     String
  phoneNumber  String?
  profileImage String?
  isVerified   Boolean       @default(false)
  status       String        @default("active")
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  incidents       Incident[]
  contacts        Contact[]
  sos             SOS[]
  alerts          Alert[]
  aiInsights      AIInsight[]
  deviceTokens    DeviceToken[]
  notifications   Notification[]
  reports         Report[]
  refreshTokens   RefreshToken[]
  
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Location {
  id          String      @id @default(uuid())
  address     String?
  city        String?
  state       String?
  country     String?
  zipCode     String?
  latitude    Float       @db.DoublePrecision
  longitude   Float       @db.DoublePrecision
  accuracy    Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  incidents   Incident[]
  sosLogs     SOSLog[]
  alerts      Alert[]

  @@index([latitude, longitude])
  @@index([city])
}

model Incident {
  id               String      @id @default(uuid())
  userId           String
  locationId       String?

  // Core incident data
  type             String      // Crime category: theft, assault, accident, etc
  description      String?
  severity         String      @default("medium")  // low, medium, high, critical
  category         String?     // Sub-category for classification
  status           String      @default("reported") // reported, investigating, resolved
  
  // Evidence & encryption
  encryptedText    String?
  encryptedFileUrl String?
  evidenceHash     String
  evidenceMimeType String?
  encryptionMeta   Json?
  
  // Geospatial
  latitude         Float?      @db.DoublePrecision
  longitude        Float?      @db.DoublePrecision
  accuracy         Float?

  // Timestamps
  timestamp        DateTime    @default(now())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // AI Analysis
  aiCategory       String?
  aiWho            String?
  aiWhen           String?
  aiType           String?
  aiSeverity       Int?
  riskScore        Float?      @default(0.0)
  aiRaw            Json?
  
  // Relations
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location         Location?   @relation(fields: [locationId], references: [id])
  aiInsights       AIInsight[]
  alerts           Alert[]
  reports          Report[]

  @@index([userId, timestamp])
  @@index([userId, type])
  @@index([userId, status])
  @@index([severity])
  @@index([status])
  @@index([riskScore])
  @@index([latitude, longitude])
  @@index([timestamp])
}

model Alert {
  id              String      @id @default(uuid())
  userId          String?
  incidentId      String
  locationId      String?
  
  title           String
  message         String
  alertType       String      // nearby_incident, sos_alert, pattern_detection
  severity        String      @default("medium")
  radius          Float?      // in meters, for proximity alerts
  status          String      @default("active") // active, resolved, dismissed
  
  createdAt       DateTime    @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime    @updatedAt
  
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  incident        Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  location        Location?   @relation(fields: [locationId], references: [id])
  
  @@index([userId])
  @@index([incidentId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model AIInsight {
  id              String   @id @default(uuid())
  userId          String
  incidentId      String?

  riskLevel       String
  legalSummary    String
  repeatedOffender String?
  escalation      Boolean  @default(false)
  confidenceScore Float?   @default(0.0)
  
  // Pattern detection
  patternType     String?  // escalation_pattern, hotspot_cluster, etc
  patternMetadata Json?
  
  // Risk analysis
  riskFactors     String[]
  recommendations String[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident        Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([incidentId])
  @@index([escalation])
}

model SOS {
  id              String   @id @default(uuid())
  userId          String
  locationId      String?

  // SOS specific
  status          String   @default("pending") // pending, activated, cancelled, resolved
  latitude        Float?   @db.DoublePrecision
  longitude       Float?   @db.DoublePrecision
  accuracy        Float?
  
  // Audio/Evidence
  encryptedAudioUrl String?
  encryptionMeta  Json?
  audioHash       String?
  
  // Notifications
  contactsNotified Int      @default(0)
  retryCount      Int      @default(0)
  
  // Timestamps
  triggeredAt     DateTime @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location        Location? @relation(fields: [locationId], references: [id])
  
  @@index([userId, triggeredAt])
  @@index([status])
  @@index([triggeredAt])
}

model Contact {
  id       String  @id @default(uuid())
  userId   String
  name     String
  phone    String
  email    String?
  priority Int     @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Notification {
  id          String  @id @default(uuid())
  userId      String
  
  title       String
  message     String
  type        String  // incident_alert, sos_broadcast, pattern_alert
  read        Boolean @default(false)
  deepLink    String?
  metadata    Json?
  
  sentAt      DateTime @default(now())
  readAt      DateTime?
  createdAt   DateTime @default(now())
  
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, read])
  @@index([createdAt])
}

model Report {
  id          String  @id @default(uuid())
  userId      String
  incidentId  String?
  
  reportType  String  // legal_summary, investigation_report, pattern_analysis
  title       String
  content     String
  status      String  @default("draft") // draft, submitted, reviewed
  
  // Report metadata
  generatedAt DateTime @default(now())
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident    Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([status])
}

model RequestNonce {
  id        String   @id @default(uuid())
  nonce     String   @unique
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
